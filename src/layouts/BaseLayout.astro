---
import '../styles/global.css';
import '../styles/note.css';
import '../styles/stacked-notes.css';

interface Props {
  title?: string;
}
const { title = 'huylenq.com' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;1,400;1,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <title>{title}</title>
</head>
<body>
  <slot />
</body>
</html>
