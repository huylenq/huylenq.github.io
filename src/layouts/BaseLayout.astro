---
import '../styles/global.css';
import '../styles/thought.css';
import '../styles/stacked-thoughts.css';
import '../styles/explorable.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
}
const { title = 'huylenq.com' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Preload header-critical font files to prevent FOUT pop-and-shrink -->
  <link rel="preload" href="https://fonts.gstatic.com/s/crimsonpro/v28/q5uDsoa5M_tv7IihmnkabARUoYF6CsKjnlQ.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="https://fonts.gstatic.com/s/crimsonpro/v28/q5uDsoa5M_tv7IihmnkabARboYF6CsKj.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7W0Q5nw.woff2" as="font" type="font/woff2" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;1,400;1,600&family=Inter:wght@400..700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" integrity="sha384-sMigJhG3fVgjMxAdTRee8N+LXOTCWB3ksYFH/Bx5pbnE6XFP3c0LaRzwVSKTSIp" crossorigin="anonymous">
  <title>{title}</title>
  <ViewTransitions />
  <script is:inline>
    // Apply theme + mode before paint to prevent FOUC
    (function() {
      var saved = localStorage.getItem('theme');
      var mode = saved || 'auto';
      if (saved === 'dark' || (!saved && matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
      document.documentElement.setAttribute('data-theme-mode', mode);
    })();
  </script>
</head>
<body>
  <slot />
  <script>
    const mq = matchMedia('(prefers-color-scheme: dark)');

    function getMode(): string {
      return localStorage.getItem('theme') || 'auto';
    }

    function getEffectiveTheme(): string {
      const mode = getMode();
      if (mode === 'auto') return mq.matches ? 'dark' : 'light';
      return mode;
    }

    function applyTheme() {
      const mode = getMode();
      const effective = getEffectiveTheme();
      document.documentElement.setAttribute('data-theme-mode', mode);
      if (effective === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }
    }

    // --- Theme hint (anchored below toggle button for auto mode) ---
    let hintTimer: number | undefined;

    function dismissThemeHint() {
      clearTimeout(hintTimer);
      const hint = document.querySelector<HTMLElement>('.theme-hint');
      if (!hint || !hint.hasAttribute('data-visible')) return;
      hint.removeAttribute('data-visible');
      hint.removeAttribute('data-fading');
    }

    function showThemeHint(text: string, btn: HTMLElement) {
      const hint = document.querySelector<HTMLElement>('.theme-hint');
      if (!hint) return;

      // Cancel any in-flight hint
      clearTimeout(hintTimer);
      hint.removeAttribute('data-fading');

      hint.textContent = text;
      hint.setAttribute('data-visible', '');

      // Position below the toggle button, centered horizontally
      const btnRect = btn.getBoundingClientRect();
      const gap = 18;
      const hintRect = hint.getBoundingClientRect();
      let left = btnRect.left + (btnRect.width - hintRect.width) / 2;
      const top = btnRect.bottom + gap;

      // Clamp to viewport edges
      const pad = 8;
      left = Math.max(pad, Math.min(left, window.innerWidth - hintRect.width - pad));

      hint.style.left = `${left}px`;
      hint.style.top = `${top}px`;

      // After 1.5s, fade out
      hintTimer = window.setTimeout(() => {
        hint.setAttribute('data-fading', '');
        const cleanup = () => {
          hint.removeAttribute('data-visible');
          hint.removeAttribute('data-fading');
        };
        hint.addEventListener('transitionend', cleanup, { once: true });
        window.setTimeout(cleanup, 400);
      }, 1500);
    }

    // Cycle: auto → light → dark → auto
    document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = getMode();
        const next = mode === 'auto' ? 'light' : mode === 'light' ? 'dark' : 'auto';
        if (next === 'auto') {
          localStorage.removeItem('theme');
        } else {
          localStorage.setItem('theme', next);
        }
        applyTheme();
        if (next === 'auto') {
          showThemeHint('Follows system theme', btn);
        } else {
          dismissThemeHint();
        }
      });
    });

    // System preference changes — only matters in auto mode
    mq.addEventListener('change', () => {
      if (getMode() === 'auto') applyTheme();
    });

    // Stamp theme onto incoming document BEFORE Astro swaps it in,
    // so copying <html> attrs preserves data-theme (no flash)
    document.addEventListener('astro:before-swap', (e) => {
      const mode = getMode();
      e.newDocument.documentElement.setAttribute('data-theme-mode', mode);
      if (getEffectiveTheme() === 'dark') {
        e.newDocument.documentElement.setAttribute('data-theme', 'dark');
      }
    });
  </script>
</body>
</html>
