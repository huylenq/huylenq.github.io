---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  section?: string;
}
const { title, section } = Astro.props;
---
<BaseLayout title={title}>
  <Header section={section} />
  <main class="essay-page">
    <slot />
  </main>
</BaseLayout>
