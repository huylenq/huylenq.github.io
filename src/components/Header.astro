---
interface Props {
  section?: string;
}
const { section } = Astro.props;
const path = Astro.url.pathname;
const sections = ['thoughts', 'explorables', 'sketches', 'resume', 'about'] as const;
const activeSection = sections.find((s) => path.startsWith(`/${s}`)) ?? null;
---
<header class="site-header" transition:persist>
  <div class="site-identity">
    <a href="/" class="site-title"><strong>Huy Le</strong></a>
    <button class="nickname" id="nickname-toggle" aria-label="Show contacts" aria-expanded="false">@huylenq <span class="reach-me">[reach me]</span></button>
    <span class="contact-links" id="contact-links">
      <a class="email-link" data-u="huy.lenq" data-d="gmail.com" href="#" aria-label="Email">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </a>
      <a href="https://t.me/huylenq" target="_blank" rel="noopener" aria-label="Telegram">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </a>
      <a href="https://github.com/huylenq" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="https://linkedin.com/in/huylenq" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </span>
    <button class="theme-toggle theme-toggle--mobile" aria-label="Toggle theme">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <svg class="icon-auto" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
      </svg>
    </button>
  </div>
  <span class="header-section-group">
    <slot name="section-extra" />
  </span>
  <nav class="site-nav">
    <svg class="nav-stroke" width="100%" height="100%" aria-hidden="true">
      <path/>
    </svg>
    {sections.map((s) => (
      <a href={`/${s}`} aria-current={activeSection === s ? 'page' : undefined} data-text={s.charAt(0).toUpperCase() + s.slice(1)}>
        {s.charAt(0).toUpperCase() + s.slice(1)}
      </a>
    ))}
    <button class="theme-toggle theme-toggle--desktop" id="theme-toggle" aria-label="Toggle theme">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <svg class="icon-auto" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
      </svg>
    </button>
  </nav>
  <span class="theme-hint" aria-hidden="true"></span>
</header>

<script>
  const toggle = document.getElementById('nickname-toggle')!;
  const links = document.getElementById('contact-links')!;

  toggle.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    links.classList.toggle('open');
    if (expanded) toggle.classList.add('just-closed');
  });

  toggle.addEventListener('mouseleave', () => {
    toggle.classList.remove('just-closed');
  });

  // Assemble email on click to defeat scrapers
  document.querySelector('.email-link')!.addEventListener('click', (e) => {
    e.preventDefault();
    const el = e.currentTarget as HTMLAnchorElement;
    window.location.href = `mailto:${el.dataset.u}@${el.dataset.d}`;
  });

  // Since the header is transition:persist, aria-current won't update on navigation â€” do it manually
  function updateActiveNav() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('.site-nav a[href]').forEach(link => {
      const href = link.getAttribute('href')!;
      const isActive = href !== '/' && path.startsWith(href);
      link.toggleAttribute('aria-current', isActive);
    });
  }

  // --- Unified nav stroke: single SVG path morphing between bar and circle ---
  import { createTimeline, cubicBezier } from 'animejs';

  const easeLeading  = cubicBezier(0.2, 1, 0.3, 1);   // springy ease-out: leading edge overshoots
  const easeTrailing = cubicBezier(0.4, 0, 0.1, 1);   // slow start, snap finish: trailing edge catches up
  const easeCircle   = cubicBezier(0.25, 1, 0.5, 1);   // smooth ease-out for circle inflate
  const easeIn       = cubicBezier(0.4, 0, 1, 1);      // ease-in for shrink & deflate

  const nav = document.querySelector<HTMLElement>('.site-nav')!;
  const pathEl = nav.querySelector<SVGPathElement>('.nav-stroke path')!;
  const navLinks = nav.querySelectorAll<HTMLAnchorElement>('a[href]');
  const desktopToggle = nav.querySelector<HTMLElement>('.theme-toggle--desktop')!;

  function clearDash() {
    pathEl.style.strokeDasharray = '';
    pathEl.style.strokeDashoffset = '0';
  }

  const K = 0.5522847498; // bezier approximation constant for quarter-circle
  const R = 16;
  const CIRC = 2 * Math.PI * R;
  const GAP_DEG = 220;
  const GAP_LEN = CIRC * GAP_DEG / 360;
  const CIRC_VIS = CIRC - GAP_LEN; // 270Â° visible arc

  // Set circle resting state: 270Â° arc with gap centered at 6 o'clock (opening downward)
  function setCircleRest() {
    pathEl.style.strokeDasharray = `${CIRC_VIS} ${GAP_LEN}`;
    pathEl.style.strokeDashoffset = `${-(GAP_LEN / 2)}`;
  }

  const colorMap: Record<string, string> = {
    '/thoughts': 'var(--accent-yellow)',
    '/explorables': 'var(--accent-blue)',
  };

  // --- Geometry: line and circle share identical M C C C C Z structure (26 values) ---
  // Both shapes use 4 cubic bezier segments so anime.js can interpolate d directly.

  // Line CCW: centerâ†’leftâ†’centerâ†’rightâ†’center (matches CCW circle for rightward motion)
  function lineCCW(lx: number, rx: number, y: number): string {
    const cx = (lx + rx) / 2;
    return `M ${cx} ${y} C ${(2*cx+lx)/3} ${y} ${(cx+2*lx)/3} ${y} ${lx} ${y} C ${(2*lx+cx)/3} ${y} ${(lx+2*cx)/3} ${y} ${cx} ${y} C ${(2*cx+rx)/3} ${y} ${(cx+2*rx)/3} ${y} ${rx} ${y} C ${(2*rx+cx)/3} ${y} ${(rx+2*cx)/3} ${y} ${cx} ${y} Z`;
  }

  // Line CW: centerâ†’rightâ†’centerâ†’leftâ†’center (matches CW circle for leftward motion)
  function lineCW(lx: number, rx: number, y: number): string {
    const cx = (lx + rx) / 2;
    return `M ${cx} ${y} C ${(2*cx+rx)/3} ${y} ${(cx+2*rx)/3} ${y} ${rx} ${y} C ${(2*rx+cx)/3} ${y} ${(rx+2*cx)/3} ${y} ${cx} ${y} C ${(2*cx+lx)/3} ${y} ${(cx+2*lx)/3} ${y} ${lx} ${y} C ${(2*lx+cx)/3} ${y} ${(lx+2*cx)/3} ${y} ${cx} ${y} Z`;
  }

  // Circle CCW from 6 o'clock: bottomâ†’leftâ†’topâ†’rightâ†’bottom
  function circleCCW(cx: number, cy: number, r: number): string {
    const k = r * K;
    return `M ${cx} ${cy+r} C ${cx-k} ${cy+r} ${cx-r} ${cy+k} ${cx-r} ${cy} C ${cx-r} ${cy-k} ${cx-k} ${cy-r} ${cx} ${cy-r} C ${cx+k} ${cy-r} ${cx+r} ${cy-k} ${cx+r} ${cy} C ${cx+r} ${cy+k} ${cx+k} ${cy+r} ${cx} ${cy+r} Z`;
  }

  // Circle CW from 6 o'clock: bottomâ†’rightâ†’topâ†’leftâ†’bottom
  function circleCW(cx: number, cy: number, r: number): string {
    const k = r * K;
    return `M ${cx} ${cy+r} C ${cx+k} ${cy+r} ${cx+r} ${cy+k} ${cx+r} ${cy} C ${cx+r} ${cy-k} ${cx+k} ${cy-r} ${cx} ${cy-r} C ${cx-k} ${cy-r} ${cx-r} ${cy-k} ${cx-r} ${cy} C ${cx-r} ${cy+k} ${cx-k} ${cy+r} ${cx} ${cy+r} Z`;
  }

  // --- Composite paths for seamless lineâ†”circle worm animation ---
  // Single open path: line segment â†’ connecting curve â†’ full circle arc
  function compositeLineToCircle(lx: number, rx: number, y: number, cx: number, cy: number, r: number, movingRight: boolean) {
    const k = r * K;
    const bot = cy + r;
    let d: string;
    if (movingRight) {
      // Arrive at 6 o'clock, continue CW (rightâ†’topâ†’leftâ†’back)
      d = `M ${lx} ${y} L ${rx} ${y}` +
        ` C ${(rx+cx)/2} ${y} ${cx} ${(y+bot)/2} ${cx} ${bot}` +
        ` C ${cx+k} ${bot} ${cx+r} ${cy+k} ${cx+r} ${cy}` +
        ` C ${cx+r} ${cy-k} ${cx+k} ${cy-r} ${cx} ${cy-r}` +
        ` C ${cx-k} ${cy-r} ${cx-r} ${cy-k} ${cx-r} ${cy}` +
        ` C ${cx-r} ${cy+k} ${cx-k} ${bot} ${cx} ${bot}`;
    } else {
      // Arrive at 6 o'clock, continue CCW (leftâ†’topâ†’rightâ†’back)
      d = `M ${rx} ${y} L ${lx} ${y}` +
        ` C ${(lx+cx)/2} ${y} ${cx} ${(y+bot)/2} ${cx} ${bot}` +
        ` C ${cx-k} ${bot} ${cx-r} ${cy+k} ${cx-r} ${cy}` +
        ` C ${cx-r} ${cy-k} ${cx-k} ${cy-r} ${cx} ${cy-r}` +
        ` C ${cx+k} ${cy-r} ${cx+r} ${cy-k} ${cx+r} ${cy}` +
        ` C ${cx+r} ${cy+k} ${cx+k} ${bot} ${cx} ${bot}`;
    }
    return { d, lineLen: Math.abs(rx - lx) };
  }

  // Reverse: circle arcs â†’ connecting curve â†’ line segment
  function compositeCircleToLine(cx: number, cy: number, r: number, lx: number, rx: number, y: number, movingRight: boolean) {
    const k = r * K;
    const bot = cy + r;
    let d: string;
    if (movingRight) {
      // Circle CW (rightâ†’topâ†’leftâ†’back to 6 o'clock), then curve out rightward to line
      d = `M ${cx} ${bot}` +
        ` C ${cx+k} ${bot} ${cx+r} ${cy+k} ${cx+r} ${cy}` +
        ` C ${cx+r} ${cy-k} ${cx+k} ${cy-r} ${cx} ${cy-r}` +
        ` C ${cx-k} ${cy-r} ${cx-r} ${cy-k} ${cx-r} ${cy}` +
        ` C ${cx-r} ${cy+k} ${cx-k} ${bot} ${cx} ${bot}` +
        ` C ${cx} ${(bot+y)/2} ${(cx+lx)/2} ${y} ${lx} ${y}` +
        ` L ${rx} ${y}`;
    } else {
      // Circle CCW (leftâ†’topâ†’rightâ†’back to 6 o'clock), then curve out leftward to line
      d = `M ${cx} ${bot}` +
        ` C ${cx-k} ${bot} ${cx-r} ${cy+k} ${cx-r} ${cy}` +
        ` C ${cx-r} ${cy-k} ${cx-k} ${cy-r} ${cx} ${cy-r}` +
        ` C ${cx+k} ${cy-r} ${cx+r} ${cy-k} ${cx+r} ${cy}` +
        ` C ${cx+r} ${cy+k} ${cx+k} ${bot} ${cx} ${bot}` +
        ` C ${cx} ${(bot+y)/2} ${(cx+rx)/2} ${y} ${rx} ${y}` +
        ` L ${lx} ${y}`;
    }
    return { d, lineLen: Math.abs(rx - lx) };
  }

  // --- State ---
  let barY = 0;
  let toggleCX = 0, toggleCY = 0;
  let currentLeftX = 0, currentRightX = 0;
  let currentShape: 'line' | 'circle' | 'none' = 'none';
  let currentAnim: ReturnType<typeof createTimeline> | null = null;
  let geometryDirty = true;

  function updateGeometry() {
    if (!geometryDirty) return;
    const navRect = nav.getBoundingClientRect();
    barY = navRect.height + 2;
    const toggleRect = desktopToggle.getBoundingClientRect();
    toggleCX = toggleRect.left - navRect.left + toggleRect.width / 2;
    toggleCY = barY - R;
    geometryDirty = false;
  }

  function invalidateGeometry() { geometryDirty = true; }

  function getActiveLink(): HTMLAnchorElement | null {
    return nav.querySelector<HTMLAnchorElement>('a[aria-current]');
  }

  function getStrokeColor(target: HTMLElement | null): string {
    if (!target) return 'var(--ink-faint)';
    if (target === desktopToggle) return 'var(--ink-medium)';
    const href = target.getAttribute('href') || '';
    return colorMap[href] || 'var(--ink-faint)';
  }

  function moveIndicatorTo(target: HTMLElement | null, shouldAnimate = true) {
    if (currentAnim) {
      currentAnim.pause();
      currentAnim = null;
    }

    updateGeometry();
    const isCircle = target === desktopToggle;
    const navRect = nav.getBoundingClientRect();

    // --- Mode 1: Instant set (resize, navigation, initial paint) ---
    if (!shouldAnimate) {
      if (target) {
        const targetRect = target.getBoundingClientRect();
        if (isCircle) {
          pathEl.setAttribute('d', circleCCW(toggleCX, toggleCY, R));
          pathEl.style.stroke = 'var(--ink-medium)';
          pathEl.style.strokeWidth = '2';
          pathEl.style.opacity = '1';
          setCircleRest();
          currentLeftX = toggleCX - 4;
          currentRightX = toggleCX + 4;
          currentShape = 'circle';
        } else {
          clearDash();
          const lx = targetRect.left - navRect.left;
          const rx = targetRect.right - navRect.left;
          pathEl.setAttribute('d', lineCCW(lx, rx, barY));
          pathEl.style.stroke = getStrokeColor(target);
          pathEl.style.strokeWidth = '2';
          pathEl.style.opacity = '1';
          currentLeftX = lx;
          currentRightX = rx;
          currentShape = 'line';
        }

      } else {
        clearDash();
        pathEl.style.opacity = '0';
        currentShape = 'none';
      }
      return;
    }

    // --- Mode 5: Shrink/hide (target = null) ---
    if (!target) {
      if (currentShape === 'circle') {
        // Erase circle stroke then fade â€” start from current 140Â° arc rest state
        pathEl.style.strokeDasharray = `${CIRC_VIS} ${GAP_LEN}`;
        const tl = createTimeline({ onComplete: clearDash });
        tl.add(pathEl, { strokeDashoffset: [-(GAP_LEN / 2), CIRC_VIS], opacity: 0, duration: 300, ease: easeIn }, 0);
        currentShape = 'none';
        currentAnim = tl;
        return;
      }
      clearDash();
      const centerX = (currentLeftX + currentRightX) / 2;
      const pointD = lineCCW(centerX, centerX, barY);

      const tl = createTimeline();
      tl.add(pathEl, { d: pointD, opacity: 0, duration: 200, ease: easeIn }, 0);
      currentShape = 'none';
      currentAnim = tl;
      return;
    }

    const targetRect = target.getBoundingClientRect();

    // --- Mode 3: â†’ toggle (morph to circle) ---
    if (isCircle) {
      if (currentShape === 'circle') return;

      const movingRight = toggleCX >= (currentLeftX + currentRightX) / 2;
      const lineFn = movingRight ? lineCCW : lineCW;
      const circleFn = movingRight ? circleCCW : circleCW;

      // From 'none': draw circle via dashoffset
      if (currentShape === 'none') {
        pathEl.setAttribute('d', circleFn(toggleCX, toggleCY, R));
        pathEl.style.stroke = 'var(--ink-medium)';
        pathEl.style.strokeWidth = '2';
        pathEl.style.opacity = '1';
        pathEl.style.strokeDasharray = `${CIRC_VIS} ${GAP_LEN}`;
        const tl = createTimeline();
        tl.add(pathEl, { strokeDashoffset: [CIRC_VIS, -(GAP_LEN / 2)], duration: 400, ease: easeCircle }, 0);
        currentLeftX = toggleCX - 4;
        currentRightX = toggleCX + 4;

        currentShape = 'circle';
        currentAnim = tl;
        return;
      }

      // From 'line': single composite path with worm dash animation
      const comp = compositeLineToCircle(currentLeftX, currentRightX, barY, toggleCX, toggleCY, R, movingRight);
      pathEl.setAttribute('d', comp.d);
      const totalLen = pathEl.getTotalLength();
      pathEl.style.stroke = 'var(--ink-medium)';
      pathEl.style.opacity = '1';

      const proxy = { leading: comp.lineLen, trailing: 0 };
      // Set initial dash state immediately to prevent flash of full composite path
      pathEl.style.strokeDasharray = `${comp.lineLen} ${totalLen}`;
      pathEl.style.strokeDashoffset = '0';
      const tl = createTimeline({
        onRender: () => {
          const dashLen = proxy.leading - proxy.trailing;
          pathEl.style.strokeDasharray = `${dashLen} ${totalLen}`;
          pathEl.style.strokeDashoffset = `${-proxy.trailing}`;
        },
        onComplete: () => {
          pathEl.setAttribute('d', circleFn(toggleCX, toggleCY, R));
          setCircleRest();
        }
      });
      tl.add(proxy, { leading: totalLen - GAP_LEN / 2, duration: 400, ease: easeLeading }, 0);
      tl.add(proxy, { trailing: totalLen - CIRC + GAP_LEN / 2, duration: 400, ease: easeTrailing }, 30);
      tl.add(pathEl, { strokeWidth: 2, duration: 400 }, 0);

      currentLeftX = toggleCX - 4;
      currentRightX = toggleCX + 4;

      currentShape = 'circle';
      currentAnim = tl;
      return;
    }

    // Target is a nav link
    const targetLX = targetRect.left - navRect.left;
    const targetRX = targetRect.right - navRect.left;
    const color = getStrokeColor(target);

    // --- Mode 4: Toggle â†’ nav link (single composite worm animation) ---
    if (currentShape === 'circle') {
      const movingRight = targetLX >= toggleCX;
      const lineFn = movingRight ? lineCCW : lineCW;

      const comp = compositeCircleToLine(toggleCX, toggleCY, R, targetLX, targetRX, barY, movingRight);
      pathEl.setAttribute('d', comp.d);
      const totalLen = pathEl.getTotalLength();
      pathEl.style.stroke = color;
      pathEl.style.opacity = '1';

      const proxy = { leading: GAP_LEN / 2 + CIRC_VIS, trailing: GAP_LEN / 2 };
      // Set initial dash state immediately to prevent flash of full composite path
      const initDash = proxy.leading - proxy.trailing;
      pathEl.style.strokeDasharray = `${initDash} ${totalLen}`;
      pathEl.style.strokeDashoffset = `${-proxy.trailing}`;
      const tl = createTimeline({
        onRender: () => {
          const dashLen = proxy.leading - proxy.trailing;
          pathEl.style.strokeDasharray = `${dashLen} ${totalLen}`;
          pathEl.style.strokeDashoffset = `${-proxy.trailing}`;
        },
        onComplete: () => {
          pathEl.setAttribute('d', lineFn(targetLX, targetRX, barY));
          clearDash();
        }
      });
      tl.add(proxy, { leading: totalLen, duration: 400, ease: easeLeading }, 0);
      tl.add(proxy, { trailing: totalLen - comp.lineLen, duration: 400, ease: easeTrailing }, 30);
      tl.add(pathEl, { strokeWidth: 2, duration: 400 }, 0);

      currentLeftX = targetLX;
      currentRightX = targetRX;

      currentShape = 'line';
      currentAnim = tl;
      return;
    }

    // --- Fade-in (currentShape = 'none') ---
    if (currentShape === 'none') {
      clearDash();
      pathEl.setAttribute('d', lineCCW(targetLX, targetRX, barY));
      pathEl.style.stroke = color;
      pathEl.style.strokeWidth = '2';
      const tl = createTimeline();
      tl.add(pathEl, { opacity: [0, 1], duration: 200 }, 0);
      currentLeftX = targetLX;
      currentRightX = targetRX;

      currentShape = 'line';
      currentAnim = tl;
      return;
    }

    // --- Mode 2: Nav link â†’ nav link (elastic stretch) ---
    clearDash();
    const movingRight = targetLX >= currentLeftX;
    const lineFn = movingRight ? lineCCW : lineCW;

    // Animate proxy object; rebuild d string each render frame
    const proxy = { leftX: currentLeftX, rightX: currentRightX };
    const tl = createTimeline({
      onRender: () => {
        pathEl.setAttribute('d', lineFn(proxy.leftX, proxy.rightX, barY));
        currentLeftX = proxy.leftX;
        currentRightX = proxy.rightX;
      }
    });

    if (movingRight) {
      // Right edge leads
      tl.add(proxy, { rightX: targetRX, duration: 300, ease: easeLeading }, 0);
      tl.add(proxy, { leftX: targetLX, duration: 350, ease: easeTrailing }, 30);
    } else {
      // Left edge leads
      tl.add(proxy, { leftX: targetLX, duration: 300, ease: easeLeading }, 0);
      tl.add(proxy, { rightX: targetRX, duration: 350, ease: easeTrailing }, 30);
    }

    pathEl.style.stroke = color;
    pathEl.style.opacity = '1';
    currentShape = 'line';
    currentAnim = tl;
  }

  // --- Event listeners ---
  navLinks.forEach(link => {
    link.addEventListener('mouseenter', () => moveIndicatorTo(link));
    link.addEventListener('click', () => {
      navLinks.forEach(l => l.removeAttribute('aria-current'));
      link.setAttribute('aria-current', 'page');
    });
  });
  desktopToggle.addEventListener('mouseenter', () => moveIndicatorTo(desktopToggle));
  nav.addEventListener('mouseleave', () => moveIndicatorTo(getActiveLink()));

  // Sync slotted content from incoming page into persisted header
  document.addEventListener('astro:before-swap', (e: any) => {
    const persistedGroup = document.querySelector('.header-section-group');
    const incomingGroup = e.newDocument.querySelector('.header-section-group');
    if (persistedGroup) {
      persistedGroup.innerHTML = incomingGroup?.innerHTML ?? '';
    }
  });

  function onNavigate() {
    invalidateGeometry();
    updateActiveNav();
    moveIndicatorTo(getActiveLink(), false);
  }
  document.addEventListener('astro:after-swap', onNavigate);

  moveIndicatorTo(getActiveLink(), false);
  window.addEventListener('resize', () => { invalidateGeometry(); moveIndicatorTo(getActiveLink(), false); });
  document.fonts.ready.then(() => { invalidateGeometry(); moveIndicatorTo(getActiveLink(), false); });
</script>

