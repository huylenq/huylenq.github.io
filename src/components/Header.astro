---
---
<header class="site-header">
  <a href="/" class="site-title"><strong>Huy Le</strong><code class="nickname">@huylenq</code></a>
  <nav class="site-nav">
    <a href="/thoughts">Thoughts</a>
    <a href="/essays">Essays</a>
    <a href="/sketches">Sketches</a>
    <a href="/cv">CV</a>
    <a href="/about">About</a>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-xl);
    border-bottom: 1px solid var(--ink-faint);
    background: var(--paper);
  }

  .site-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-black);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .site-title code.nickname {
    text-transform: none;
    font-size: .7rem;
    margin-left: .8rem;
    color: var(--ink-light);
  }

  .site-title:hover {
    text-decoration: none;
    color: var(--ink-dark);
  }

  .site-nav {
    display: flex;
    gap: var(--space-lg);
  }

  .site-nav a {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink-medium);
    text-decoration: none;
  }

  .site-nav a:hover {
    color: var(--ink-black);
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink-medium);
    padding: 2px;
    display: flex;
    align-items: center;
    line-height: 1;
  }

  .theme-toggle:hover {
    color: var(--ink-black);
  }

  /* Show sun in dark mode, moon in light mode */
  .icon-sun { display: none; }
  .icon-moon { display: block; }
  :global([data-theme="dark"]) .icon-sun { display: block; }
  :global([data-theme="dark"]) .icon-moon { display: none; }
</style>
