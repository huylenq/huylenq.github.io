---
interface Props {
  section?: string;
}
const { section } = Astro.props;
const path = Astro.url.pathname;
const sections = ['thoughts', 'essays', 'sketches', 'resume', 'about'] as const;
const activeSection = sections.find((s) => path.startsWith(`/${s}`)) ?? null;
---
<header class="site-header" transition:persist>
  <div class="site-identity">
    <a href="/" class="site-title"><strong>Huy Le</strong></a>
    <button class="nickname" id="nickname-toggle" aria-label="Show contacts" aria-expanded="false">@huylenq <span class="reach-me">[reach me]</span></button>
    <span class="contact-links" id="contact-links">
      <a class="email-link" data-u="huy.lenq" data-d="gmail.com" href="#" aria-label="Email">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </a>
      <a href="https://t.me/huylenq" target="_blank" rel="noopener" aria-label="Telegram">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </a>
      <a href="https://github.com/huylenq" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="https://linkedin.com/in/huylenq" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </span>
    <button class="theme-toggle theme-toggle--mobile" aria-label="Toggle dark mode">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
  <span class="header-section-group">
    <slot name="section-extra" />
  </span>
  <nav class="site-nav">
    {sections.map((s) => (
      <a href={`/${s}`} aria-current={activeSection === s ? 'page' : undefined}>
        {s.charAt(0).toUpperCase() + s.slice(1)}
      </a>
    ))}
    <span class="nav-indicator" aria-hidden="true"></span>
    <button class="theme-toggle theme-toggle--desktop" id="theme-toggle" aria-label="Toggle dark mode">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nickname-toggle')!;
  const links = document.getElementById('contact-links')!;

  toggle.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    links.classList.toggle('open');
    if (expanded) toggle.classList.add('just-closed');
  });

  toggle.addEventListener('mouseleave', () => {
    toggle.classList.remove('just-closed');
  });

  // Assemble email on click to defeat scrapers
  document.querySelector('.email-link')!.addEventListener('click', (e) => {
    e.preventDefault();
    const el = e.currentTarget as HTMLAnchorElement;
    window.location.href = `mailto:${el.dataset.u}@${el.dataset.d}`;
  });

  // Since the header is transition:persist, aria-current won't update on navigation — do it manually
  function updateActiveNav() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('.site-nav a[href]').forEach(link => {
      const href = link.getAttribute('href')!;
      const isActive = href !== '/' && path.startsWith(href);
      link.toggleAttribute('aria-current', isActive);
    });
  }

  // --- Sliding nav indicator ---
  const nav = document.querySelector<HTMLElement>('.site-nav')!;
  const indicator = nav.querySelector<HTMLElement>('.nav-indicator')!;
  const navLinks = nav.querySelectorAll<HTMLAnchorElement>('a[href]');

  const colorMap: Record<string, string> = {
    '/thoughts': 'var(--accent-yellow)',
    '/essays': 'var(--accent-blue)',
  };

  function getActiveLink(): HTMLAnchorElement | null {
    return nav.querySelector<HTMLAnchorElement>('a[aria-current]');
  }

  let lastLeft = 0;

  function moveIndicatorTo(link: HTMLAnchorElement | null, animate = true) {
    if (!link) {
      if (!animate) {
        indicator.style.transition = 'none';
        indicator.removeAttribute('data-direction');
        indicator.style.setProperty('--ind-opacity', '0');
        indicator.offsetHeight;
        indicator.style.transition = '';
        return;
      }
      // Shrink to center of current position
      const currentLeft = parseFloat(indicator.style.getPropertyValue('--ind-left')) || 0;
      const currentRight = parseFloat(indicator.style.getPropertyValue('--ind-right')) || 0;
      const navWidth = nav.getBoundingClientRect().width;
      const barWidth = navWidth - currentLeft - currentRight;
      const center = currentLeft + barWidth / 2;

      indicator.setAttribute('data-direction', 'shrink');
      indicator.style.setProperty('--ind-left', `${center}px`);
      indicator.style.setProperty('--ind-right', `${navWidth - center}px`);
      indicator.style.setProperty('--ind-opacity', '0');
      return;
    }

    const navRect = nav.getBoundingClientRect();
    const linkRect = link.getBoundingClientRect();
    const newLeft = linkRect.left - navRect.left;
    const newRight = navRect.right - linkRect.right;
    const href = link.getAttribute('href') || '';
    const color = colorMap[href] || 'var(--ink-faint)';

    if (!animate) {
      indicator.style.transition = 'none';
      indicator.removeAttribute('data-direction');
    } else {
      // Set direction so CSS picks the right staggered transition
      indicator.setAttribute('data-direction', newLeft >= lastLeft ? 'right' : 'left');
    }

    indicator.style.setProperty('--ind-left', `${newLeft}px`);
    indicator.style.setProperty('--ind-right', `${newRight}px`);
    indicator.style.setProperty('--ind-opacity', '1');
    indicator.style.backgroundColor = color;
    lastLeft = newLeft;

    if (!animate) {
      // Force reflow then restore transition
      indicator.offsetHeight;
      indicator.style.transition = '';
    }
  }

  // Hover: slide to hovered link, return to active on leave
  navLinks.forEach(link => {
    link.addEventListener('mouseenter', () => moveIndicatorTo(link));
  });
  nav.addEventListener('mouseleave', () => moveIndicatorTo(getActiveLink()));

  // Navigation: update active state, then slide indicator
  function onNavigate() {
    updateActiveNav();
    moveIndicatorTo(getActiveLink(), false);
  }
  document.addEventListener('astro:after-swap', onNavigate);

  // Initial paint — no animation
  moveIndicatorTo(getActiveLink(), false);

  // Reposition on resize (no animation)
  window.addEventListener('resize', () => moveIndicatorTo(getActiveLink(), false));

  // Handle late font metric changes
  document.fonts.ready.then(() => moveIndicatorTo(getActiveLink(), false));
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-xl);
    border-bottom: 1px solid var(--ink-faint);
    background: var(--paper);
  }

  .site-identity {
    display: inline-flex;
    align-items: center;
    gap: 0;
  }

  .site-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-black);
    text-decoration: none;
  }

  .site-title:hover {
    text-decoration: none;
    color: var(--ink-dark);
  }

  .nickname {
    all: unset;
    cursor: pointer;
    font-family: var(--font-mono, monospace);
    font-size: .7rem;
    margin-left: .8rem;
    color: var(--ink-medium);
    position: relative;
  }

  .reach-me {
    position: absolute;
    left: calc(100% + 0.6em);
    top: 50%;
    transform: translateY(-50%);
    opacity: 0;
    white-space: nowrap;
    pointer-events: none;
  }

  .nickname:hover:not([aria-expanded="true"]):not(.just-closed) .reach-me {
    opacity: 1;
    transition: opacity 0.08s ease;
  }

  .nickname:hover {
    color: var(--ink-dark);
  }

  .contact-links {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    margin-left: var(--space-md);
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    transition: max-width 0.3s ease, opacity 0.25s ease;
  }

  .contact-links.open {
    max-width: 12rem;
    opacity: 1;
  }

  .contact-links a {
    color: var(--ink-dark);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  .contact-links a:hover {
    color: var(--ink-black);
  }

  .header-section-group {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }


  .site-nav {
    display: flex;
    gap: var(--space-lg);
    position: relative;
  }

  .site-nav a {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink-medium);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-nav a:hover,
  .site-nav a[aria-current] {
    color: var(--ink-black);
  }

  .nav-indicator {
    position: absolute;
    bottom: -3px;
    height: 2px;
    left: var(--ind-left, 0px);
    right: var(--ind-right, 0px);
    opacity: var(--ind-opacity, 0);
    background-color: var(--ink-faint);
    border-radius: 1px;
    pointer-events: none;
    will-change: left, right;
    /* Default (no direction yet): uniform transition */
    transition: left 0.35s cubic-bezier(0.25, 1, 0.5, 1),
                right 0.35s cubic-bezier(0.25, 1, 0.5, 1),
                background-color 0.2s ease,
                opacity 0.2s ease;
  }

  /* Moving right: right (leading) edge races ahead, left (trailing) edge catches up */
  .nav-indicator[data-direction="right"] {
    transition: left 0.35s cubic-bezier(0.4, 0, 0.1, 1) 0.03s,
                right 0.3s cubic-bezier(0.2, 1, 0.3, 1),
                background-color 0.2s ease,
                opacity 0.2s ease;
  }

  /* Moving left: left (leading) edge races ahead, right (trailing) edge catches up */
  .nav-indicator[data-direction="left"] {
    transition: left 0.3s cubic-bezier(0.2, 1, 0.3, 1),
                right 0.35s cubic-bezier(0.4, 0, 0.1, 1) 0.03s,
                background-color 0.2s ease,
                opacity 0.2s ease;
  }

  /* Shrink: both edges collapse to center, opacity snaps off after */
  .nav-indicator[data-direction="shrink"] {
    transition: left 0.15s cubic-bezier(0.4, 0, 1, 1),
                right 0.15s cubic-bezier(0.4, 0, 1, 1),
                opacity 0s 0.15s;
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink-medium);
    padding: 2px;
    display: flex;
    align-items: center;
    line-height: 1;
  }

  .theme-toggle:hover {
    color: var(--ink-black);
  }

  /* Show sun in dark mode, moon in light mode */
  .icon-sun { display: none; }
  .icon-moon { display: block; }
  :global([data-theme="dark"]) .icon-sun { display: block; }
  :global([data-theme="dark"]) .icon-moon { display: none; }

  /* Mobile toggle hidden by default (desktop only shows the nav one) */
  .theme-toggle--mobile { display: none; }

  @media (max-width: 1024px) {
    .header-section-group {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .site-header {
      flex-wrap: wrap;
      padding: var(--space-xs) var(--space-md);
      row-gap: var(--space-xs);
    }

    .site-identity {
      position: relative;
      width: 100%;
      justify-content: center;
    }

    .site-identity::before {
      content: "@huylenq";
      visibility: hidden;
      font-family: var(--font-mono, monospace);
      font-size: .7rem;
      margin-right: .8rem;
      order: -1;
    }

    .site-nav {
      width: 100%;
      justify-content: center;
      gap: var(--space-md);
    }

    .contact-links.open {
      margin-right: 1.8rem;
    }

    .theme-toggle--desktop { display: none; }

    .theme-toggle--mobile {
      display: flex;
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
    }
  }
</style>
