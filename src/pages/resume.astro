---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---
<BaseLayout title="Resume">
  <Header section="Resume">
    <a slot="section-extra" class="download-button" download="Huy CV.pdf" href="/assets/huy-cv.pdf">
      <svg class="download-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline class="arrow" points="7 10 12 15 17 10" />
        <line class="arrow" x1="12" y1="15" x2="12" y2="3" />
      </svg>
    </a>
  </Header>
  <div class="cv-page">

    <object data="/assets/huy-cv.pdf" type="application/pdf" width="100%" height="1000px">
      <div class="pdf-fallback">
        <svg class="warning-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F0AB46" stroke-width="2">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
          <line x1="12" y1="9" x2="12" y2="13" />
          <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
        <em>Seems like your browser doesn't support embedding PDFs. Please use the download link above.</em>
      </div>
    </object>
  </div>
</BaseLayout>

<style>
  @keyframes downward {
    0% { transform: translateY(-2px); }
    50% { transform: translateY(2px); }
    100% { transform: translateY(-2px); }
  }

  .cv-page {
    padding: 0;
  }

  .download-button {
    display: inline-flex;
    align-items: center;
    color: var(--ink-medium);
  }

  .download-button .arrow {
    animation: downward 1s ease-in-out infinite;
  }

  .download-button:hover {
    text-decoration: none;
    color: var(--ink-dark);
  }

  .download-button:hover .arrow {
    stroke: #3b82f6;
  }

  .pdf-fallback {
    border: 1px solid #F0AB46;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 1rem;
  }

  .warning-icon {
    flex-shrink: 0;
  }
</style>
