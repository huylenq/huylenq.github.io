---
import PageLayout from '../../layouts/PageLayout.astro';
import ThoughtGraph from '../../components/ThoughtGraph.tsx';
import fs from 'node:fs';
import path from 'node:path';
import type { ThoughtGraphFile } from '../../lib/types';

const defaultGraphFile: ThoughtGraphFile = { thoughts: {}, edges: [] };
let graphFile = defaultGraphFile;
const graphPath = path.join(process.cwd(), 'content/thoughts/_graph.json');
if (fs.existsSync(graphPath)) {
  graphFile = JSON.parse(fs.readFileSync(graphPath, 'utf-8'));
}

const thoughts = Object.values(graphFile.thoughts);
const edges = graphFile.edges;
---
<PageLayout title="Thoughts — huylenq.com" section="Thoughts">
  <section class="listing-section">
    {thoughts.length > 0 ? (
      <>
        <div class="graph-desktop">
          <ThoughtGraph client:media="(min-width: 768px)" thoughts={thoughts} edges={edges} fillViewport />
        </div>
        <ul class="listing graph-mobile">
          {thoughts.map((thought) => (
            <li>
              <a href={`/thoughts/${thought.slug}`}>{thought.title}</a>
            </li>
          ))}
        </ul>
      </>
    ) : (
      <p class="empty">No thoughts published yet.</p>
    )}
  </section>
</PageLayout>

<style>
  /* Remove page-content padding so graph fills viewport below header */
  .listing-section {
    margin-top: calc(-1 * var(--space-xl));
  }

  /* Break out of .page-content container to full width */
  .graph-desktop {
    display: block;
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }
  .graph-mobile {
    display: none;
  }

  @media (max-width: 767px) {
    .graph-desktop {
      display: none;
    }
    .graph-mobile {
      display: block;
    }
  }

  .listing {
    list-style: none;
    padding: 0;
  }

  .listing li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--ink-faint);
  }

  .listing li:last-child {
    border-bottom: none;
  }

  .listing a {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-dark);
    text-decoration: none;
  }

  .listing a:hover {
    color: var(--ink-black);
  }

  .empty {
    color: var(--ink-light);
    font-style: italic;
  }
</style>
