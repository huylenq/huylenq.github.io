---
import PageLayout from '../../layouts/PageLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import type { ThoughtGraph } from '../../lib/types';

let graph: ThoughtGraph = {};
const graphPath = path.join(process.cwd(), 'content/thoughts/_graph.json');
if (fs.existsSync(graphPath)) {
  graph = JSON.parse(fs.readFileSync(graphPath, 'utf-8'));
}

const thoughts = Object.values(graph);
---
<PageLayout title="Thoughts — huylenq.com">
  <section class="listing-section">
    <h2>Thoughts</h2>
    {thoughts.length > 0 ? (
      <ul class="listing">
        {thoughts.map((thought) => (
          <li>
            <a href={`/thoughts/${thought.slug}`}>{thought.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No thoughts published yet.</p>
    )}
  </section>
</PageLayout>

<style>
  .listing-section h2 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--ink-black);
  }

  .listing {
    list-style: none;
    padding: 0;
  }

  .listing li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--ink-faint);
  }

  .listing li:last-child {
    border-bottom: none;
  }

  .listing a {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-dark);
    text-decoration: none;
  }

  .listing a:hover {
    color: var(--ink-black);
  }

  .empty {
    color: var(--ink-light);
    font-style: italic;
  }
</style>
