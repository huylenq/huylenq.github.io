---
import PageLayout from '../layouts/PageLayout.astro';

const books = [
  { title: 'Atomic Habits', author: 'James Clear', cover: '51Eqf-URhoL' },
  { title: 'Deep Work', author: 'Cal Newport', cover: '51vmivI5KvL' },
  { title: 'Sapiens', author: 'Yuval Noah Harari', cover: '51Sn8PEXwcL' },
  { title: 'Algorithms to Live By', author: 'Brian Christian & Tom Griffiths', cover: '51FhJXhhK6L' },
  { title: 'A Game of Thrones', author: 'George R. R. Martin', cover: '518dkA0JEpL' },
  { title: 'Staff Engineer', author: 'Will Larson & Tanya Reilly', cover: '71cPGL5jLTL' },
  { title: 'Why We Sleep', author: 'Matthew Walker', cover: '51b36-UW0xL' },
  { title: 'Range', author: 'David Epstein', cover: '41nLL-wUTXL' },
  { title: 'Never Split the Difference', author: 'Chris Voss & Tahl Raz', cover: '51yKczFDuQL' },
  { title: "The Subtle Art of Not Giving a F*ck", author: 'Mark Manson', cover: '51mN3bY0JjL' },
  { title: 'Thinking in Systems', author: 'Donella H. Meadows', cover: '51q+TMvkNFL' },
  { title: 'An Elegant Puzzle', author: 'Will Larson', cover: '51aTO3pGp9L' },
];

const topShelf = books.slice(0, 6);
const bottomShelf = books.slice(6, 12);

// Deterministic height variations per book (seeded by index)
const heightOffsets = [4, -6, 2, -3, 7, -4, 5, -2, 6, -5, 3, -7];
---

<PageLayout title="Bookshelf">
  <h1>Bookshelf</h1>
  <p class="intro">A few books that left a mark.</p>

  <div class="bookshelf">
    {[topShelf, bottomShelf].map((shelf, shelfIdx) => (
      <div class="shelf-row">
        <div class="books">
          {shelf.map((book, i) => {
            const globalIdx = shelfIdx * 5 + i;
            const hOffset = heightOffsets[globalIdx];
            return (
              <div
                class="book"
                style={`--h-offset: ${hOffset}px`}

              >
                <img
                  src={`https://m.media-amazon.com/images/I/${book.cover}._SL500_.jpg`}
                  alt={`${book.title} by ${book.author}`}
                  loading="lazy"
                />
              </div>
            );
          })}
        </div>
        <div class="shelf-plank" />
      </div>
    ))}
  </div>

</PageLayout>

<style>
  /* Override page-content for bookshelf layout */
  :global(.page-content:has(.bookshelf)) {
    display: flex;
    flex-direction: column;
    max-width: none;
    min-height: calc(100vh - var(--header-height, 2.5rem));
    padding-bottom: 0;
  }

  h1 {
    font-size: 1.6em;
    margin: 0 auto 0.4em;
    max-width: var(--max-width);
    padding: 0 var(--space-xl);
  }

  .intro {
    color: var(--text-secondary);
    margin: 0 auto var(--space-lg);
    max-width: var(--max-width);
    padding: 0 var(--space-xl);
  }

  /* --- Bookshelf structure: tủ âm tường (recessed wall alcove) --- */
  .bookshelf {
    max-width: 950px;
    width: 100%;
    margin: 0 auto var(--space-xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-lg) 0;
    position: relative;
    overflow: hidden;

    /* Back panel + inner side-wall depth gradients */
    background:
      /* Left wall depth */
      linear-gradient(to right, rgba(0,0,0,0.5), rgba(0,0,0,0.12) 20px, transparent 50px),
      /* Right wall depth */
      linear-gradient(to left, rgba(0,0,0,0.5), rgba(0,0,0,0.12) 20px, transparent 50px),
      /* Top wall depth */
      linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.08) 25px, transparent 55px),
      /* Bottom wall depth */
      linear-gradient(to top, rgba(0,0,0,0.25), rgba(0,0,0,0.05) 20px, transparent 40px),
      /* Back panel texture */
      url('/assets/bookshelf/back.jpg') center / cover;

    /* Wall cutout frame — beveled inward (darker top = shadow from overhang) */
    border: 10px solid;
    border-color: #cec9c0 #dbd7cf #e5e2db #dbd7cf;
    border-radius: 3px;

    /* Recess depth shadows */
    box-shadow:
      /* Deep ambient recess */
      inset 0 0 70px rgba(0,0,0,0.45),
      /* Top overhang shadow */
      inset 0 10px 25px rgba(0,0,0,0.35),
      /* Side depth */
      inset 6px 0 18px rgba(0,0,0,0.2),
      inset -6px 0 18px rgba(0,0,0,0.2),
      /* Inner lip — dark line at frame/recess transition */
      inset 0 0 0 1px rgba(0,0,0,0.2),
      /* Outer: subtle cast shadow on the wall */
      0 2px 12px rgba(0,0,0,0.08),
      0 0 0 1px rgba(0,0,0,0.03);
  }

  .shelf-row {
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 2;
  }

  .books {
    display: flex;
    justify-content: center;
    gap: 14px;
    align-items: flex-end;
    padding: 20px 40px 0;
  }

  /* --- Individual book (3D skeuomorphic) --- */
  .book {
    flex: 0 1 120px;
    min-width: 80px;
    cursor: default;
    position: relative;
    transform: translateY(var(--h-offset, 0px));
    transition: transform 0.3s ease, filter 0.3s ease;
    /* 3D context for the book */
    transform-style: preserve-3d;
    perspective: 600px;
  }

  .book img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    border-radius: 3px 1px 1px 3px;
    position: relative;
    z-index: 1;
    /* Stacked box-shadows: page layers create visible thickness */
    box-shadow:
      /* page layers — each offset creates a "page edge" */
      1px 1px 0 0 #d5d0c8,
      2px 1px 0 0 #cec9c1,
      3px 2px 0 0 #c7c2ba,
      4px 2px 0 0 #c0bbb3,
      5px 3px 0 0 #b9b4ac,
      /* edge shadow — soft shadow hugging the page stack */
      5px 3px 4px 1px rgba(0, 0, 0, 0.35),
      /* depth shadows beyond the page stack */
      8px 6px 8px rgba(0, 0, 0, 0.3),
      12px 10px 20px rgba(0, 0, 0, 0.18);
  }

  /* Spine: left edge with rounded highlight */
  .book::before {
    content: '';
    position: absolute;
    top: 0;
    left: -5px;
    width: 7px;
    height: 180px;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.2),
      rgba(255, 255, 255, 0.1) 40%,
      rgba(0, 0, 0, 0.25)
    );
    border-radius: 3px 0 0 3px;
    z-index: 2;
  }

  .book:hover {
    transform: translateY(calc(var(--h-offset, 0px) - 10px));
    filter: brightness(1.05);
  }

  .book:hover img {
    box-shadow:
      1px 1px 0 0 #d5d0c8,
      2px 1px 0 0 #cec9c1,
      3px 2px 0 0 #c7c2ba,
      4px 2px 0 0 #c0bbb3,
      5px 3px 0 0 #b9b4ac,
      5px 3px 4px 1px rgba(0, 0, 0, 0.35),
      10px 8px 10px rgba(0, 0, 0, 0.3),
      16px 14px 28px rgba(0, 0, 0, 0.18);
  }

  /* --- Shelf plank (3D skeuomorphic) --- */
  .shelf-plank {
    flex-shrink: 0;
    position: relative;
    height: 14px;
    transform-style: preserve-3d;
    perspective: 400px;
    /* top surface — wood texture, slightly lit from above */
    background:
      linear-gradient(to bottom, rgba(255, 255, 255, 0.04), rgba(0, 0, 0, 0.1)),
      url('/assets/bookshelf/shelf.jpg') center / cover;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    /* protrude past the back panel on both sides */
    margin-left: -10px;
    margin-right: -10px;
    /* space for the angled front face below */
    margin-bottom: 28px;
  }

  /* Front face — tilted back as seen from above */
  .shelf-plank::before {
    content: '';
    position: absolute;
    top: 100%;
    left: -2px;
    right: -2px;
    height: 28px;
    transform-origin: top center;
    transform: rotateX(-20deg);
    background:
      /* lighting: highlight at top edge, darkens as face angles away */
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.12) 0%,
        rgba(255, 255, 255, 0.03) 8%,
        transparent 25%,
        rgba(0, 0, 0, 0.1) 60%,
        rgba(0, 0, 0, 0.3) 100%
      ),
      /* real wood texture — offset from top surface for continuous grain */
      url('/assets/bookshelf/shelf.jpg') -320px center / cover;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid #1a1008;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      inset 0 -3px 6px rgba(0, 0, 0, 0.35),
      inset 0 0 12px rgba(0, 0, 0, 0.2);
    filter: brightness(0.7);
  }

  /* Shadow cast by the shelf onto the back panel below */
  .shelf-plank::after {
    content: '';
    position: absolute;
    top: calc(100% + 20px);
    left: 0;
    right: 0;
    height: 28px;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.4),
      rgba(0, 0, 0, 0.15) 35%,
      rgba(0, 0, 0, 0.04) 70%,
      transparent
    );
    pointer-events: none;
  }

/* --- Dark mode --- */
  :global([data-theme="dark"]) .bookshelf {
    filter: brightness(0.85);
    border-color: #2a2826 #333130 #3a3836 #333130;
  }

  /* --- Mobile --- */
  @media (max-width: 768px) {
    .bookshelf {
      margin-left: var(--space-sm);
      margin-right: var(--space-sm);
      border-width: 7px;
    }

    .books {
      gap: 8px;
      padding: 14px 12px 0;
    }

    .book {
      width: 90px;
      min-width: 48px;
    }

    .book img {
      height: 135px;
    }

    .book::before {
      height: 135px;
      left: -3px;
      width: 4px;
    }

    .shelf-plank {
      height: 16px;
      border-bottom-width: 6px;
    }

    .shelf-plank::after {
      height: 6px;
      bottom: -6px;
    }
  }
</style>
