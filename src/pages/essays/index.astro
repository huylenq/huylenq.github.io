---
import PageLayout from '../../layouts/PageLayout.astro';

const essayModules = import.meta.glob('../../essays/*.mdx', { eager: true }) as Record<string, any>;
const sorted = Object.values(essayModules)
  .filter((e) => e.meta?.title)
  .sort((a, b) => new Date(b.meta.date).getTime() - new Date(a.meta.date).getTime());
---
<PageLayout title="Essays — huylenq.com" section="Essays">
  <section class="listing-section">
    {sorted.length > 0 ? (
      <ul class="listing">
        {sorted.map((essay) => (
          <li>
            <a href={`/essays/${essay.meta.slug}`}>{essay.meta.title}</a>
            {essay.meta.description && (
              <span class="description">— {essay.meta.description}</span>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No essays published yet.</p>
    )}
  </section>
</PageLayout>

<style>
  .listing {
    list-style: none;
    padding: 0;
  }

  .listing li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--ink-faint);
  }

  .listing li:last-child {
    border-bottom: none;
  }

  .listing a {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-dark);
    text-decoration: none;
  }

  .listing a:hover {
    color: var(--ink-black);
  }

  .description {
    color: var(--ink-medium);
    margin-left: 0.5em;
  }

  .empty {
    color: var(--ink-light);
    font-style: italic;
  }
</style>
