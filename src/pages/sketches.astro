---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout title="Sketches">
  <h1>Sketches</h1>
  <p class="intro">
    Sketching is probably the nearest experience with "zen" moment for me.
    Everything is shoved sideways, just next stroke after next stroke.
  </p>

  <div class="gallery">
    <figure class="sketch" data-src="/sketches/fed-up-man.mp4">
      <div class="thumb">
        <video muted preload="metadata" tabindex="-1">
          <source src="/sketches/fed-up-man.mp4" type="video/mp4" />
        </video>
        <div class="play-icon" aria-hidden="true">&#9654;</div>
      </div>
      <figcaption>Straw hat man</figcaption>
    </figure>

    <figure class="sketch" data-src="/sketches/just-a-cup.mp4">
      <div class="thumb">
        <video muted preload="metadata" tabindex="-1">
          <source src="/sketches/just-a-cup.mp4" type="video/mp4" />
        </video>
        <div class="play-icon" aria-hidden="true">&#9654;</div>
      </div>
      <figcaption>Just a Cup</figcaption>
    </figure>

    <figure class="sketch" data-src="/sketches/face-planes.mp4">
      <div class="thumb">
        <video muted preload="metadata" tabindex="-1">
          <source src="/sketches/face-planes.mp4" type="video/mp4" />
        </video>
        <div class="play-icon" aria-hidden="true">&#9654;</div>
      </div>
      <figcaption>A planar face practice</figcaption>
    </figure>

    <figure class="sketch" data-src="/sketches/shiba-the-reporter.mp4">
      <div class="thumb">
        <video muted preload="metadata" tabindex="-1">
          <source src="/sketches/shiba-the-reporter.mp4" type="video/mp4" />
        </video>
        <div class="play-icon" aria-hidden="true">&#9654;</div>
      </div>
      <figcaption>Shiba the Reporter</figcaption>
    </figure>
  </div>

  <dialog class="video-overlay" id="video-overlay">
    <video muted controls id="overlay-video"></video>
    <p class="overlay-caption" id="overlay-caption"></p>
  </dialog>
</PageLayout>

<style>
  h1 {
    font-size: 1.6em;
    margin-bottom: 0.4em;
  }

  .intro {
    color: var(--text-secondary);
    margin-bottom: var(--space-2xl);
  }

  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl) var(--space-lg);
  }

  .sketch {
    margin: 0;
    cursor: pointer;
  }

  .thumb {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
  }

  .thumb video {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
  }

  .play-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: #fff;
    background: rgba(0, 0, 0, 0.25);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .sketch:hover .play-icon {
    opacity: 1;
  }

  .sketch figcaption {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-medium);
    margin-top: var(--space-xs);
  }

  /* Overlay */
  .video-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    width: 100vw;
    height: 100vh;
    max-width: none;
    max-height: none;
    border: none;
    background: rgba(0, 0, 0, 0.92);
    padding: 0;
    margin: 0;
    outline: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .video-overlay:not([open]) {
    display: none;
  }

  .video-overlay::backdrop {
    display: none;
  }

  .video-overlay video {
    max-width: 85vw;
    max-height: 80vh;
    display: block;
  }

  .overlay-caption {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-top: var(--space-sm);
    text-align: center;
  }

  @media (max-width: 520px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const overlay = document.getElementById('video-overlay') as HTMLDialogElement;
  const overlayVideo = document.getElementById('overlay-video') as HTMLVideoElement;
  const overlayCaption = document.getElementById('overlay-caption')!;

  document.querySelectorAll('.sketch').forEach(sketch => {
    sketch.addEventListener('click', () => {
      const src = (sketch as HTMLElement).dataset.src!;
      const caption = sketch.querySelector('figcaption')?.textContent || '';
      overlayVideo.src = src;
      overlayCaption.textContent = caption;
      overlay.showModal();
      overlayVideo.play();
    });
  });

  // Click backdrop to close
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) {
      overlay.close();
    }
  });

  // Clean up on close (Esc or backdrop click)
  overlay.addEventListener('close', () => {
    overlayVideo.pause();
    overlayVideo.removeAttribute('src');
    overlayVideo.load();
  });
</script>
