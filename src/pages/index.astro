---
import PageLayout from '../layouts/PageLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import type { ThoughtGraph } from '../lib/types';

let graph: ThoughtGraph = {};
const graphPath = path.join(process.cwd(), 'content/thoughts/_graph.json');
if (fs.existsSync(graphPath)) {
  graph = JSON.parse(fs.readFileSync(graphPath, 'utf-8'));
}

const thoughts = Object.values(graph);

const essayModules = import.meta.glob('../essays/*.mdx', { eager: true }) as Record<string, any>;
const essays = Object.values(essayModules)
  .filter((e) => e.meta?.title)
  .sort((a, b) => new Date(b.meta.date).getTime() - new Date(a.meta.date).getTime());
---
<PageLayout title="huylenq.com">
  <p class="intro">
    Welcome. I'm Huy — a programmer who sketches, reads, and occasionally writes.
  </p>

  <nav class="page-links">
    <a href="/sketches">Sketches</a>
    <a href="/cv">CV</a>
    <a href="/about">About</a>
  </nav>

  <section class="thoughts-section">
    <h2>Thoughts</h2>
    {thoughts.length > 0 ? (
      <ul class="thoughts-list">
        {thoughts.map((thought) => (
          <li>
            <a href={`/thoughts/${thought.slug}`}>{thought.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No thoughts published yet.</p>
    )}
  </section>

  <section class="thoughts-section">
    <h2>Essays</h2>
    {essays.length > 0 ? (
      <ul class="thoughts-list">
        {essays.map((essay) => (
          <li>
            <a href={`/essays/${essay.meta.slug}`}>{essay.meta.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No essays published yet.</p>
    )}
  </section>
</PageLayout>

<style>
  .intro {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--ink-medium);
    margin-bottom: var(--space-2xl);
  }

  .page-links {
    display: flex;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .page-links a {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink-medium);
    text-decoration: none;
  }

  .page-links a:hover {
    color: var(--ink-black);
  }

  .thoughts-section + .thoughts-section {
    margin-top: var(--space-2xl);
  }

  .thoughts-section h2 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--ink-black);
  }

  .thoughts-list {
    list-style: none;
    padding: 0;
  }

  .thoughts-list li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--ink-faint);
  }

  .thoughts-list li:last-child {
    border-bottom: none;
  }

  .thoughts-list a {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-dark);
    text-decoration: none;
  }

  .thoughts-list a:hover {
    color: var(--ink-black);
  }

  .empty {
    color: var(--ink-light);
    font-style: italic;
  }
</style>
