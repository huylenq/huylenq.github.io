---
import PageLayout from '../layouts/PageLayout.astro';
import ThoughtGraph from '../components/ThoughtGraph.tsx';
import fs from 'node:fs';
import path from 'node:path';
import type { ThoughtGraphFile } from '../lib/types';

const defaultGraphFile: ThoughtGraphFile = { thoughts: {}, edges: [] };
let graphFile = defaultGraphFile;
const graphPath = path.join(process.cwd(), 'content/thoughts/_graph.json');
if (fs.existsSync(graphPath)) {
  graphFile = JSON.parse(fs.readFileSync(graphPath, 'utf-8'));
}

const thoughts = Object.values(graphFile.thoughts);
const edges = graphFile.edges;

const essayModules = import.meta.glob('../essays/*.mdx', { eager: true }) as Record<string, any>;
const essays = Object.values(essayModules)
  .filter((e) => e.meta?.title)
  .sort((a, b) => new Date(b.meta.date).getTime() - new Date(a.meta.date).getTime());
---
<PageLayout title="huylenq.com">
  <p class="intro">
    Welcome. I'm Huy — a programmer who sketches, reads, and occasionally writes.
  </p>

  <section class="thoughts-section">
    <h2>Thoughts</h2>
    <p class="section-description">My shower thoughts, put together.</p>
    {thoughts.length > 0 ? (
      <>
        <div class="graph-desktop">
          <ThoughtGraph client:media="(min-width: 768px)" thoughts={thoughts} edges={edges} />
        </div>
        <ul class="thoughts-list graph-mobile">
          {thoughts.map((thought) => (
            <li>
              <a href={`/thoughts/${thought.slug}`}>{thought.title}</a>
            </li>
          ))}
        </ul>
      </>
    ) : (
      <p class="empty">No thoughts published yet.</p>
    )}
  </section>

  <section class="thoughts-section">
    <h2>Essays</h2>
    <p class="section-description">Interactive, play-able essays that I'm having fun making.</p>
    {essays.length > 0 ? (
      <ul class="thoughts-list">
        {essays.map((essay) => (
          <li>
            <a href={`/essays/${essay.meta.slug}`}><strong>{essay.meta.title}</strong></a>
            {essay.meta.description && (
              <span class="essay-description">— {essay.meta.description}</span>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No essays published yet.</p>
    )}
  </section>
</PageLayout>

<style>
  .intro {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--ink-medium);
    margin-bottom: var(--space-2xl);
  }

  .thoughts-section + .thoughts-section {
    margin-top: var(--space-2xl);
  }

  .section-description {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-medium);
    font-style: italic;
    margin-top: calc(-1 * var(--space-sm));
    margin-bottom: var(--space-lg);
  }

  .thoughts-section h2 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--ink-black);
  }

  .thoughts-list {
    list-style: none;
    padding: 0;
  }

  .thoughts-list li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--ink-faint);
  }

  .thoughts-list li:last-child {
    border-bottom: none;
  }

  .thoughts-list a {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-dark);
    text-decoration: none;
  }

  .thoughts-list a:hover {
    color: var(--ink-black);
  }

  .essay-description {
    color: var(--ink-medium);
    margin-left: 0.5em;
  }

  .empty {
    color: var(--ink-light);
    font-style: italic;
  }

  /* Graph: break out of .page-content container to full width */
  .graph-desktop {
    display: block;
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin-left: 0;
    margin-right: 0;
  }
  .graph-mobile {
    display: none;
  }

  @media (max-width: 767px) {
    .graph-desktop {
      display: none;
    }
    .graph-mobile {
      display: block;
    }
  }
</style>
