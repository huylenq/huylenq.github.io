---
import PageLayout from '../layouts/PageLayout.astro';
import Bio from '../components/Bio.astro';
import ThoughtGraph from '../components/ThoughtGraph.tsx';
import fs from 'node:fs';
import path from 'node:path';
import type { ThoughtGraphFile } from '../lib/types';

const defaultGraphFile: ThoughtGraphFile = { thoughts: {}, edges: [] };
let graphFile = defaultGraphFile;
const graphPath = path.join(process.cwd(), 'content/thoughts/_graph.json');
if (fs.existsSync(graphPath)) {
  graphFile = JSON.parse(fs.readFileSync(graphPath, 'utf-8'));
}

const maturityOrder: Record<string, number> = { evergreen: 0, budding: 1, seed: 2 };
const thoughts = Object.values(graphFile.thoughts)
  .sort((a, b) => (maturityOrder[a.maturity] ?? 2) - (maturityOrder[b.maturity] ?? 2));
const edges = graphFile.edges;

const essayModules = import.meta.glob('../essays/*.mdx', { eager: true }) as Record<string, any>;
const essays = Object.values(essayModules)
  .filter((e) => e.meta?.title)
  .sort((a, b) => new Date(b.meta.date).getTime() - new Date(a.meta.date).getTime());
---
<PageLayout title="huylenq.com">
  <div class="intro">
    <Bio />
  </div>

  <section class="thoughts-section" data-accent="yellow">
    <h2><a href="/thoughts">Thoughts</a></h2>
    <p class="section-description">My shower thoughts, put together. Some of these are just incoherent thought dump placeholders.</p>
    {thoughts.length > 0 ? (
      <>
        <div class="graph-desktop">
          <ThoughtGraph client:media="(min-width: 768px)" thoughts={thoughts} edges={edges} />
        </div>
        <ul class="thoughts-list graph-mobile">
          {thoughts.map((thought) => (
            <li data-maturity={thought.maturity ?? "seed"}>
              <a href={`/thoughts/${thought.slug}`}>{thought.title}</a>
            </li>
          ))}
        </ul>
      </>
    ) : (
      <p class="empty">No thoughts published yet.</p>
    )}
  </section>

  <section class="thoughts-section" data-accent="blue">
    <h2><a href="/essays">Essays</a></h2>
    <p class="section-description">Interactive, play-able essays that I'm having fun making.</p>
    {essays.length > 0 ? (
      <ul class="thoughts-list">
        {essays.map((essay) => (
          <li>
            <a href={`/essays/${essay.meta.slug}`} class="essay-link">
              <strong>{essay.meta.title}</strong>
              {essay.meta.description && (
                <span class="essay-description">— {essay.meta.description}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No essays published yet.</p>
    )}
  </section>
</PageLayout>

<style>
  .intro {
    margin-bottom: var(--space-2xl);
  }

  .thoughts-section + .thoughts-section {
    margin-top: var(--space-2xl);
  }

  .section-description {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-medium);
    font-style: italic;
    margin-top: calc(-1 * var(--space-sm));
    margin-bottom: var(--space-lg);
  }

  .thoughts-section h2 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--ink-black);
  }

  .thoughts-section[data-accent] h2 {
    border-bottom-width: 2px;
  }

  :global([data-theme="dark"]) .thoughts-section[data-accent] h2 {
    border-bottom-width: 1px;
  }

  .thoughts-section[data-accent="yellow"] h2 {
    border-bottom-color: var(--accent-yellow);
  }

  .thoughts-section[data-accent="blue"] h2 {
    border-bottom-color: var(--accent-blue);
  }

  .thoughts-section h2 a {
    color: inherit;
    text-decoration: none;
  }

  .thoughts-list {
    list-style: none;
    padding: 0;
  }

  .thoughts-list li {
    padding: var(--space-sm) 0 var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--ink-faint);
    border-left: 3px solid var(--ink-faint);
  }

  .thoughts-list li[data-maturity="budding"] {
    border-left-color: var(--ink-medium);
  }

  .thoughts-list li[data-maturity="evergreen"] {
    border-left-color: var(--ink-dark);
  }

  .thoughts-list li:last-child {
    border-bottom: none;
  }

  .thoughts-list a {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-dark);
    text-decoration: none;
  }

  .thoughts-list a:hover {
    color: var(--ink-black);
  }

  .essay-link {
    display: block;
  }

  .essay-description {
    color: var(--ink-medium);
    margin-left: 0.5em;
  }

  .empty {
    color: var(--ink-light);
    font-style: italic;
  }

  /* Graph: break out of .page-content container to full width */
  .graph-desktop {
    display: block;
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin-left: 0;
    margin-right: 0;
  }
  .graph-mobile {
    display: none;
  }

  @media (max-width: 767px) {
    .graph-desktop {
      display: none;
    }
    .graph-mobile {
      display: block;
    }
  }
</style>
