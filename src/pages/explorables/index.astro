---
import PageLayout from '../../layouts/PageLayout.astro';

const modules = import.meta.glob('../../explorables/*.mdx', { eager: true }) as Record<string, any>;
const sorted = Object.values(modules)
  .filter((e) => e.meta?.title)
  .sort((a, b) => new Date(b.meta.date).getTime() - new Date(a.meta.date).getTime());
---
<PageLayout title="Explorables — huylenq.com" section="Explorables">
  <section class="listing-section">
    <p class="section-description">Interactive, play-able explorations that I'm having fun making.</p>
    {sorted.length > 0 ? (
      <ul class="listing">
        {sorted.map((item) => (
          <li>
            <a href={`/explorables/${item.meta.slug}`}>
              <strong>{item.meta.title}</strong>
              {item.meta.description && (
                <span class="description">— {item.meta.description}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No explorables published yet.</p>
    )}
  </section>
</PageLayout>

<style>
  .section-description {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-medium);
    font-style: italic;
    margin-bottom: var(--space-lg);
  }

  .listing {
    list-style: none;
    padding: 0;
  }

  .listing li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--ink-faint);
  }

  .listing li:last-child {
    border-bottom: none;
  }

  .listing a {
    display: block;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-dark);
    text-decoration: none;
  }

  .listing a:hover {
    color: var(--ink-black);
  }

  .description {
    color: var(--ink-medium);
    margin-left: 0.5em;
  }

  .empty {
    color: var(--ink-light);
    font-style: italic;
  }
</style>
